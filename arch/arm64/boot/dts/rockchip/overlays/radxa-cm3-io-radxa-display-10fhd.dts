/dts-v1/;
/plugin/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/display/drm_mipi_dsi.h>
#include "dt-bindings/display/drm_mipi_dsi_overlay.h"
#include <dt-bindings/pwm/pwm.h>

/ {
	metadata {
		title = "Enable Radxa Display 10FHD";
		compatible = "radxa,cm3-io";
		category = "display";
		exclusive = "dsi1", "vp0", "video_phy1", "pwm2";
		description = "Enable Radxa Display 10FHD.";
	};
};

&{/} {
	vcc_lcd_mipi1: vcc-lcd-mipi1 {
		status = "okay";
		compatible = "regulator-fixed";
		regulator-name = "vcc_lcd_mipi1";
		pinctrl-names = "default";
		pinctrl-0 = <&vcc_mipi>;
		gpio = <&gpio0 RK_PD6 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-always-on;
		regulator-state-mem {
			regulator-off-in-suspend;
		};
	};

	vcc_lcd_tp: vcc-lcd-tp {
		status = "okay";
		compatible = "regulator-fixed";
		regulator-name = "vcc_lcd_tp";
		pinctrl-names = "default";
		pinctrl-0 = <&vcc_tp>;
		gpio = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
		regulator-always-on;
		regulator-state-mem {
			regulator-off-in-suspend;
		};
	};

	dsi1_backlight: dsi1-backlight {
		status = "okay";
		compatible = "pwm-backlight";
		pwms = <&pwm2 0 25000 PWM_POLARITY_INVERTED>;
		brightness-levels = <0 255>;
		num-interpolated-steps = <255>;
		default-brightness-level = <250>;
		enable-gpios = <&gpio3 RK_PD7 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&dsi1_backlight_en>;
	};
};

&pwm2 {
	status = "okay";
};

&dsi1 {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	dsi1_panel: panel@0 {
		status = "okay";
		compatible = "simple-panel-dsi";
		reg = <0>;
		backlight = <&dsi1_backlight>;

		power-supply = <&vcc_lcd_mipi1>;
		reset-gpios = <&gpio4 RK_PA0 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&dsi1_lcd_rst_gpio>;

		prepare-delay-ms = <120>;
		reset-delay-ms = <120>;
		init-delay-ms = <120>;
		enable-delay-ms = <100>;
		disable-delay-ms = <120>;
		unprepare-delay-ms = <120>;

		width-mm = <135>;
		height-mm = <217>;

		dsi,flags = <(MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST |
			MIPI_DSI_MODE_LPM | MIPI_DSI_MODE_EOT_PACKET)>;
		dsi,format = <MIPI_DSI_FMT_RGB888>;
		dsi,lanes = <4>;

		panel-init-sequence = [
			05 78 01 11
			05 00 01 29
		];

		panel-exit-sequence = [
			05 00 01 28
			05 00 01 10
		];

		display_timings0: display-timings {
			native-mode = <&dsi1_timing>;

			dsi1_timing: timing0 {
				clock-frequency = <160000000>;
				hactive = <1200>;
				vactive = <1920>;

				vback-porch = <25>;
				vfront-porch = <35>;

				hback-porch = <60>;
				hfront-porch = <80>;

				hsync-len = <1>;
				vsync-len = <1>;

				vsync-active = <0>;
				hsync-active = <0>;
				de-active = <0>;
				pixelclk-active = <0>;
			};
		};

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				panel_in_dsi1: endpoint {
					remote-endpoint = <&dsi1_out_panel>;
				};
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			dsi1_out_panel: endpoint {
				remote-endpoint = <&panel_in_dsi1>;
			};
		};
	};
};

&video_phy1 {
	status = "okay";
};

&dsi1_in_vp0 {
	status = "okay";
};

&dsi1_in_vp1 {
	status = "disabled";
};

&vp0_out_dsi1 {
	status = "okay";
};

&vp1_out_dsi1 {
	status = "disabled";
};

&route_dsi1 {
	status = "okay";
	connect = <&vp0_out_dsi1>;
};

&i2c2 {
	status = "okay";
	pinctrl-0 = <&i2c2m1_xfer>;
	clock-frequency = <400000>;
	#address-cells = <1>;
	#size-cells = <0>;

	gt9xx: gt9xx@14 {
		status = "okay";
		compatible = "goodix,gt9xx";
		reg = <0x14>;
		pinctrl-names = "default";
		pinctrl-0 = <&gt9xx_gpio>;
		touch-gpio = <&gpio0 RK_PB3 IRQ_TYPE_LEVEL_HIGH>;
		reset-gpio = <&gpio0 RK_PB4 GPIO_ACTIVE_HIGH>;
		max-x = <1200>;
		max-y = <1920>;
		tp-size = <9271>;
		tp-supply = <&vcc_lcd_tp>;
	};
};

&hdmi {
	status = "disabled";
};

&hdmi_in_vp0 {
	status = "disabled";
};

&hdmi_sound {
	status = "disabled";
};

&route_hdmi {
	status = "disabled";
};

&pinctrl {
	lcd-vcc {
		vcc_mipi: vcc-mipi {
			rockchip,pins = <0 RK_PD6 RK_FUNC_GPIO &pcfg_pull_up>;
		};

		vcc_tp: vcc-tp {
			rockchip,pins = <4 RK_PA1 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	dsi1-lcd {
		dsi1_lcd_rst_gpio: dsi1-lcd-rst-gpio {
			rockchip,pins = <4 RK_PA0 RK_FUNC_GPIO &pcfg_pull_up>;
		};

		dsi1_backlight_en: dsi1-backlight-en {
			rockchip,pins = <3 RK_PD7 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	gt9xx {
		gt9xx_gpio: gt9xx-gpio {
			rockchip,pins =
			<0 RK_PB4 RK_FUNC_GPIO &pcfg_pull_up>,
			<0 RK_PB3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};
