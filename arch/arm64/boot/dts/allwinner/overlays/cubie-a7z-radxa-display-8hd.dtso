/dts-v1/;
/plugin/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/gpio/sun4i-gpio.h>
#include <dt-bindings/display/sunxi-lcd.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	metadata {
		title = "Enable Radxa Display 8HD for Cubie A7Z V2.0+";
		compatible = "radxa,cubie-a7z";
		category = "display";
		exclusive = "dlcd0", "dsi0", "dsi0combophy", "PD18", "PD19", "PD16", "PD17", "PD15", "PE15";
		description = "Enable Radxa Display 8HD for Cubie A7Z V2.0+";
	};
};

&{/} {

	pwm_gpio: pwm-gpio {
		compatible = "pwm-gpio";
		#pwm-cells = <3>;
		pwm-gpios = <&pio PE 15 GPIO_ACTIVE_HIGH>;
	};

	backlight0: backlight0 {
		compatible = "pwm-backlight";
		status = "okay";
		brightness-levels = <1 255>;
		num-interpolated-steps = <255>;
		default-brightness-level = <200>;
		pwms = <&pwm_gpio 0 25000 0>;
	};

	dsi_panel: dsi_panel@1 {
		compatible = "allwinner,panel-dsi";
		status = "okay";
		power-delay-ms = <10>;
		power0-supply = <&reg_dc1sw1>;
		power1-supply = <&reg_bldo2>;
		
		reset-num = <1>;
		reset-delay-ms = <20>;
		reset-gpios = <&pio PD 15 GPIO_ACTIVE_HIGH>;
		backlight = <&backlight0>;
		dsi,flags = <(MIPI_DSI_MODE_VIDEO)>;
		dsi,lanes = <4>;
		dsi,format = <0>;

		panel-init-sequence = [
			15 00 02 E0 00
			15 00 02 E1 93
			15 00 02 E2 65
			15 00 02 E3 F8
			15 00 02 80 03

			15 00 02 E0 01
			15 00 02 00 00
			15 00 02 01 7E
			15 00 02 03 00
			15 00 02 04 65
			15 00 02 0C 74
			15 00 02 17 00
